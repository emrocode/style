{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "items": [
    {
      "name": "app-header",
      "type": "registry:block",
      "title": "Header",
      "description": "A header component",
      "registryDependencies": ["@emrocode/hero"],
      "files": [
        {
          "path": "app-header/app-header.tsx",
          "type": "registry:component"
        }
      ]
    },
    {
      "name": "github-corner",
      "type": "registry:component",
      "title": "GitHub Corner",
      "description": "A simple GitHub corner component",
      "files": [
        {
          "path": "github-corner/github-corner.tsx",
          "type": "registry:component"
        }
      ],
      "cssVars": {
        "theme": {
          "--animate-wave": "wave 0.777s ease-in-out"
        }
      },
      "css": {
        "@keyframes wave": {
          "0%, 100%": {
            "transform": "rotate(0)"
          },
          "20%, 60%": {
            "transform": "rotate(-25deg)"
          },
          "40%, 80%": {
            "transform": "rotate(10deg)"
          }
        }
      }
    },
    {
      "name": "layout",
      "type": "registry:block",
      "title": "Layout",
      "description": "Core layout configuration with pre-configured providers",
      "registryDependencies": [
        "@emrocode/font-archivo",
        "@emrocode/theme-provider"
      ],
      "files": [
        {
          "path": "layout/layout.tsx",
          "type": "registry:component",
          "target": "app/layout.tsx"
        }
      ]
    },
    {
      "name": "theme-provider",
      "type": "registry:component",
      "title": "Theme Provider",
      "description": "A theme provider using @emrocode/umbra",
      "dependencies": ["@emrocode/umbra"],
      "files": [
        {
          "path": "theme-provider/theme-provider.tsx",
          "type": "registry:component"
        },
        {
          "path": "theme-provider/plugins/index.ts",
          "type": "registry:component",
          "target": "@components/plugins/index.ts"
        },
        {
          "path": "theme-provider/plugins/kbd.plugin.ts",
          "type": "registry:component",
          "target": "@components/plugins/kbd.plugin.ts"
        }
      ],
      "css": {
        "@custom-variant dark": {
          "&:where([data-theme=dark] *)": {
            "@slot": {}
          }
        }
      }
    }
  ]
}
